# --- Required: from your Supabase project settings > API ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# --- Optional but strongly recommended ---
# A TURN server relays video when two people can't connect directly
# (common on corporate/school wifi and some mobile carriers). Without
# it, calls will still work most of the time on open home networks,
# but will sometimes fail to connect at all. See SETUP.md for how to
# get these values (e.g. from Cloudflare Calls, Twilio, or your own
# coturn server).
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
